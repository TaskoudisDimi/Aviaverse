# ─── Aviaverse Academy — Production Environment ───────────────────────────────
# Copy this file to .env.prod and fill in all values before deploying.
# NEVER commit .env.prod to git.

# JWT secret (strong random string — generate with: openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32

# Google Gemini API key (https://aistudio.google.com → API Keys)
GEMINI_API_KEY=AIza...

# PostgreSQL password (choose a strong one)
POSTGRES_PASSWORD=choose_a_strong_password_here
